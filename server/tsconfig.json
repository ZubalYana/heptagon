{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "typeRoots": ["./src/types", "./node_modules/@types"],
    "name": "heptagon-server",
    "version": "1.0.0",
    "scripts": {
      "start": "node dist/app.js",
      "dev": "ts-node src/app.ts",
      "build": "tsc"
    }
  },
  "include": ["src/**/*"]
}
